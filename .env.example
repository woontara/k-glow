# PostgreSQL 연결 문자열 (Supabase 등)
# 예: postgresql://user:password@localhost:5432/kglow
DATABASE_URL=

# NextAuth 세션 암호화 키
# 생성: openssl rand -base64 32  (또는 npx auth secret)
NEXTAUTH_SECRET=

# 배포 URL (로컬 개발 시 http://localhost:3000)
NEXTAUTH_URL=http://localhost:3000

# OpenAI API 키 (AI 분석/번역에 사용)
OPENAI_API_KEY=
